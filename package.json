{
    "name": "lta-madt-gui",
    "version": "5.1.17",
    "private": true,
    "scripts": {
        "build": "ng build  --aot --output-hashing=all",
        "start": "ng serve",
        "start:local:network": "ng serve --host=0.0.0.0 --disable-host-check",
        "test": "ng test",
        "ng:clear:cache": "ng cache clean",
        "test:clean": "ng cache clean",
        "lint:check": "npm run lint:check:eslint && npm run lint:check:prettier",
        "lint:check:eslint": "npx eslint .",
        "lint:check:prettier": "npx prettier --check './**/*.{ts,tsx,js,jsx,md,json,css,scss,less}'",
        "lint:fix": "npm run lint:fix:eslint && npm run lint:fix:prettier",
        "lint:fix:eslint": "npx eslint --fix .",
        "lint:fix:prettier": "npx prettier --write './**/*.{ts,tsx,js,jsx,md,json,css,scss,less}'",
        "prepare": "husky",
        "start:build": "lite-server",
        "serve:ssr:lta-btds-gui": "node dist/lta-btds-gui/server/server.mjs",
        "watch": "ng build --watch --configuration development",
        "lint": "ng lint"
    },
    "dependencies": {
        "@angular/animations": "^20.2.2",
        "@angular/cdk": "^20.2.1",
        "@angular/common": "^20.2.2",
        "@angular/compiler": "^20.2.2",
        "@angular/core": "^20.2.2",
        "@angular/forms": "^20.2.2",
        "@angular/material": "^20.2.1",
        "@angular/platform-browser": "^20.2.2",
        "@angular/platform-browser-dynamic": "^20.2.2",
        "@angular/platform-server": "^20.2.2",
        "@angular/router": "^20.2.2",
        "@angular/ssr": "^20.2.1",
        "@ngrx/store": "^20.0.1",
        "@ngx-translate/core": "^17.0.0",
        "@ngx-translate/http-loader": "^17.0.0",
        "@types/mqtt": "^2.5.0",
        "express": "^4.18.2",
        "mqtt": "^5.14.1",
        "ngx-scrollbar": "^15.1.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0",
        "zone.js": "~0.15.1"
    },
    "devDependencies": {
        "@angular-eslint/builder": "^20.0.0",
        "@angular-eslint/eslint-plugin": "^20.0.0",
        "@angular-eslint/eslint-plugin-template": "^20.0.0",
        "@angular-eslint/schematics": "^20.7.0",
        "@angular-eslint/template-parser": "^20.0.0",
        "@angular/build": "^20.2.1",
        "@angular/cli": "^20.2.1",
        "@angular/compiler-cli": "^20.2.2",
        "@types/express": "^4.17.17",
        "@types/jasmine": "~5.1.0",
        "@types/node": "^24.3.0",
        "@typescript-eslint/eslint-plugin": "^8.41.0",
        "@typescript-eslint/parser": "^8.41.0",
        "@typescript-eslint/type-utils": "^8.41.0",
        "@typescript-eslint/utils": "^8.41.0",
        "baseline-browser-mapping": "^2.9.8",
        "eslint": "^9.34.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-simple-import-sort": "12.1.0",
        "husky": "9.0.11",
        "jasmine-core": "~5.1.0",
        "karma": "~6.4.0",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.0",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "lint-staged": "15.2.2",
        "lite-server": "^2.6.1",
        "prettier": "3.2.5",
        "prettier-eslint": "^16.3.0",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.41.0"
    }
}
